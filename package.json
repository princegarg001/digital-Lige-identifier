    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "mic": "^2.1.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "phonemize": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sentiment": "^5.0.2",
    "simplex-noise": "^4.0.3",
    "speaker": "^0.5.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "wawa-lipsync": "^0.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
