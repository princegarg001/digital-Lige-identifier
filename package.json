    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/pino": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sentiment": "^5.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
