{
  "name": "digital-persona",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "predev": "npm run lint:fix && npm run lint && npm run typecheck",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "health-check": "ts-node scripts/health-check.ts",
    "pre-deploy": "npm run health-check && npm run test:run && npm run build",
    "validate-avatar": "node scripts/validate-avatar.mjs",
    "setup-avatar": "node scripts/download-animations.mjs && npm run validate-avatar"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@radix-ui/react-slot": "^1.2.4",
